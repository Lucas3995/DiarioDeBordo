<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DiarioDeBordo.UI.ViewModels"
        xmlns:dto="using:DiarioDeBordo.Module.Acervo.DTOs"
        x:Class="DiarioDeBordo.UI.Views.ConteudoDetalheWindow"
        x:DataType="vm:ConteudoDetalheViewModel"
        Width="720"
        Height="640"
        MinWidth="600"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        CanResize="True"
        Title="{Binding TituloJanela}"
        AutomationProperties.Name="Janela de detalhe e edição de conteúdo">

    <Grid RowDefinitions="*,Auto">

        <!-- Row 0: Scrollable content with 4 Expander sections -->
        <ScrollViewer Grid.Row="0"
                      Padding="32,24,32,16"
                      AutomationProperties.Name="Área de conteúdo do detalhe">

            <StackPanel Spacing="12">

                <!-- Error message -->
                <TextBlock Text="{Binding MensagemErro}"
                           IsVisible="{Binding MensagemErro, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           Foreground="Red"
                           FontSize="13"
                           AutomationProperties.Name="Mensagem de erro" />

                <!-- 1. Identificação (expanded by default — primary editing section) -->
                <Expander IsExpanded="True"
                          AutomationProperties.Name="Seção Identificação: título, descrição, anotações, formato">

                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Identificação"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ResumoIdentificacao}"
                                       FontSize="12"
                                       Opacity="0.6"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>

                    <StackPanel Spacing="12" Margin="0,12,0,0">

                        <!-- Título (obrigatório) -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Título"
                                       FontWeight="Medium" />
                            <TextBox Text="{Binding Titulo, Mode=TwoWay}"
                                     Watermark="Ex: Duna, A Origem, Cálculo Vol. 1…"
                                     AutomationProperties.Name="Campo título do conteúdo"
                                     AutomationProperties.HelpText="Obrigatório. Digite o título do conteúdo." />
                        </StackPanel>

                        <!-- Descrição -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Descrição"
                                       FontWeight="Medium" />
                            <TextBox Text="{Binding Descricao, Mode=TwoWay}"
                                     AcceptsReturn="True"
                                     Height="80"
                                     Watermark="Descrição breve do conteúdo…"
                                     AutomationProperties.Name="Campo descrição do conteúdo" />
                        </StackPanel>

                        <!-- Anotações -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Anotações"
                                       FontWeight="Medium" />
                            <TextBox Text="{Binding Anotacoes, Mode=TwoWay}"
                                     AcceptsReturn="True"
                                     Height="80"
                                     Watermark="Notas pessoais, resumos, destaques…"
                                     AutomationProperties.Name="Campo anotações do conteúdo" />
                        </StackPanel>

                        <!-- Formato -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Formato"
                                       FontWeight="Medium" />
                            <ComboBox SelectedItem="{Binding Formato, Mode=TwoWay}"
                                      ItemsSource="{x:Static vm:ConteudoDetalheViewModel.FormatosMidia}"
                                      HorizontalAlignment="Left"
                                      MinWidth="200"
                                      AutomationProperties.Name="Seleção de formato do conteúdo"
                                      AutomationProperties.HelpText="Selecione o tipo de mídia (livro, filme, série, etc.)" />
                        </StackPanel>

                        <!-- Subtipo -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Subtipo"
                                       FontWeight="Medium" />
                            <TextBox Text="{Binding Subtipo, Mode=TwoWay}"
                                     Watermark="Ex: Romance, Ficção científica, Drama…"
                                     AutomationProperties.Name="Campo subtipo do conteúdo" />
                        </StackPanel>

                    </StackPanel>

                </Expander>

                <!-- 2. Avaliação (collapsed — nota, classificação, progresso) -->
                <Expander IsExpanded="False"
                          AutomationProperties.Name="Seção Avaliação: nota e classificação">

                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Avaliação"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ResumoAvaliacao}"
                                       FontSize="12"
                                       Opacity="0.6"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>

                    <StackPanel Spacing="12" Margin="0,12,0,0">

                        <!-- Nota field (UI-SPEC §5) -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Nota (0–10)"
                                       FontWeight="Medium" />
                            <Grid ColumnDefinitions="Auto,Auto">
                                <NumericUpDown Grid.Column="0"
                                              Value="{Binding Nota}"
                                              Minimum="0"
                                              Maximum="10"
                                              Increment="0.5"
                                              FormatString="0.#"
                                              Width="100"
                                              Watermark="—"
                                              AutomationProperties.Name="Nota pessoal de 0 a 10"
                                              AutomationProperties.HelpText="Opcional. Use setas ou digite um valor entre 0 e 10." />
                                <Button Grid.Column="1"
                                        Content="✕"
                                        Padding="4"
                                        Command="{Binding LimparNotaCommand}"
                                        IsVisible="{Binding Nota, Converter={x:Static ObjectConverters.IsNotNull}}"
                                        AutomationProperties.Name="Limpar nota"
                                        Margin="4,0,0,0" />
                            </Grid>
                        </StackPanel>

                        <!-- Classificação selector (UI-SPEC §4, three-state D-07) -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Classificação"
                                       FontWeight="Medium" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        AutomationProperties.Name="{Binding ClassificacaoTexto, StringFormat='Classificação: {0}'}">
                                <ToggleButton IsChecked="{Binding IsGostei}"
                                             Width="36"
                                             Height="36"
                                             AutomationProperties.Name="Marcar como Gostei">
                                    <TextBlock Text="👍" FontSize="20" />
                                </ToggleButton>
                                <ToggleButton IsChecked="{Binding IsNaoGostei}"
                                             Width="36"
                                             Height="36"
                                             AutomationProperties.Name="Marcar como Não gostei">
                                    <TextBlock Text="👎" FontSize="20" />
                                </ToggleButton>
                            </StackPanel>
                        </StackPanel>

                        <!-- Progresso (estado + posição) -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Progresso"
                                       FontWeight="Medium" />
                            <Grid ColumnDefinitions="Auto,*">
                                <ComboBox Grid.Column="0"
                                          Width="150"
                                          ItemsSource="{Binding EstadosProgresso}"
                                          SelectedItem="{Binding EstadoProgresso, Mode=TwoWay}"
                                          AutomationProperties.Name="Estado de progresso" />
                                <TextBox Grid.Column="1"
                                         Margin="8,0,0,0"
                                         Text="{Binding PosicaoAtual, Mode=TwoWay}"
                                         Watermark="Ex: Página 120, Episódio 5…"
                                         AutomationProperties.Name="Posição atual no conteúdo" />
                            </Grid>
                        </StackPanel>

                    </StackPanel>

                </Expander>

                <!-- 3. Organização (collapsed — categorias e relações) -->
                <Expander IsExpanded="False"
                          AutomationProperties.Name="Seção Organização: categorias e relações">

                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Organização"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ResumoOrganizacao}"
                                       FontSize="12"
                                       Opacity="0.6"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>

                    <StackPanel Spacing="12" Margin="0,12,0,0">

                        <!-- Categorias section -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Categorias"
                                       FontWeight="Medium" />

                            <!-- Chips -->
                            <ItemsControl x:Name="CategoriasLista"
                                          ItemsSource="{Binding CategoriasAssociadas}"
                                          AutomationProperties.Name="Categorias associadas">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CategoriaChipViewModel">
                                        <Border CornerRadius="14"
                                                Padding="8,4"
                                                Margin="4,2"
                                                Height="28"
                                                Background="{Binding Background}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="{Binding NomeExibicao}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center" />
                                                <Button Content="✕"
                                                        Padding="2"
                                                        FontSize="10"
                                                        Command="{Binding RemoverCommand}"
                                                        CommandParameter="{Binding Id}"
                                                        AutomationProperties.Name="{Binding Nome, StringFormat='Remover categoria {0}'}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- AutoCompleteBox for adding categories -->
                            <AutoCompleteBox Name="CategoriaAutoComplete"
                                             Watermark="Adicionar categoria…"
                                             FilterMode="None"
                                             MinimumPrefixLength="1"
                                             MinimumPopulateDelay="200"
                                             AutomationProperties.Name="Campo de busca e criação de categorias"
                                             MinWidth="200" />

                            <!-- Empty state -->
                            <TextBlock Text="Nenhuma categoria associada"
                                       IsVisible="{Binding !CategoriasAssociadas.Count}"
                                       Opacity="0.6"
                                       FontSize="12" />
                        </StackPanel>

                        <!-- Relações section -->
                        <StackPanel Spacing="4"
                                    Margin="0,8,0,0">
                            <TextBlock Text="Relações"
                                       FontWeight="Medium" />

                            <!-- Existing relations list -->
                            <ItemsControl x:Name="RelacoesLista"
                                          ItemsSource="{Binding Relacoes}"
                                          AutomationProperties.Name="Lista de relações do conteúdo">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RelacaoItemViewModel">
                                        <Border Padding="8,4"
                                                Margin="0,2"
                                                CornerRadius="4"
                                                BorderThickness="1"
                                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Grid.Column="0"
                                                            Orientation="Horizontal"
                                                            Spacing="4">
                                                    <TextBlock Text="{Binding NomeTipo}"
                                                               FontSize="13" />
                                                    <TextBlock Text="→"
                                                               Opacity="0.6"
                                                               FontSize="13" />
                                                    <TextBlock Text="{Binding TituloDestino}"
                                                               FontSize="13" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Padding="4"
                                                        Command="{Binding RemoverCommand}"
                                                        CommandParameter="{Binding Id}"
                                                        AutomationProperties.Name="{Binding TituloDestino, StringFormat='Remover relação com {0}'}">
                                                    <TextBlock Text="🗑" FontSize="12" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Empty state -->
                            <TextBlock Text="Nenhuma relação definida"
                                       IsVisible="{Binding !Relacoes.Count}"
                                       Opacity="0.6"
                                       FontSize="12" />

                            <!-- Error message -->
                            <TextBlock Text="{Binding MensagemErroRelacao}"
                                       IsVisible="{Binding MensagemErroRelacao, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Foreground="Red"
                                       FontSize="12" />

                            <!-- Add relation button -->
                            <Button Content="Adicionar relação"
                                    Command="{Binding MostrarFormularioRelacaoCommand}"
                                    IsVisible="{Binding !MostrandoFormularioRelacao}"
                                    AutomationProperties.Name="Adicionar nova relação"
                                    Margin="0,4,0,0" />

                            <!-- Inline add form -->
                            <Border IsVisible="{Binding MostrandoFormularioRelacao}"
                                    Padding="12"
                                    CornerRadius="4"
                                    Margin="0,4"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                                <StackPanel Spacing="8">

                                    <!-- Step 1: Search target content -->
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Conteúdo alvo" FontSize="12" />
                                        <AutoCompleteBox Name="ConteudoAlvoAutoComplete"
                                                         Watermark="Buscar conteúdo para vincular…"
                                                         FilterMode="None"
                                                         MinimumPrefixLength="1"
                                                         MinimumPopulateDelay="300"
                                                         AutomationProperties.Name="Buscar conteúdo para relacionar" />
                                    </StackPanel>

                                    <!-- Step 2: Select relation type -->
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Tipo de relação" FontSize="12" />
                                        <AutoCompleteBox Name="TipoRelacaoAutoComplete"
                                                         Watermark="Selecionar tipo…"
                                                         FilterMode="None"
                                                         MinimumPrefixLength="0"
                                                         MinimumPopulateDelay="200"
                                                         AutomationProperties.Name="Selecionar tipo de relação" />
                                        <!-- Inverse name field (shown when creating new type) -->
                                        <StackPanel IsVisible="{Binding CriandoNovoTipo}" Spacing="4">
                                            <TextBlock Text="Nome inverso (ex: 'Continuação de')" FontSize="12" />
                                            <TextBox Text="{Binding NomeInversoNovoTipo, Mode=TwoWay}"
                                                     Watermark="Ex: Continuação de"
                                                     AutomationProperties.Name="Nome inverso do tipo de relação" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Actions -->
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                HorizontalAlignment="Right">
                                        <Button Content="Cancelar"
                                                Command="{Binding CancelarFormularioRelacaoCommand}"
                                                AutomationProperties.Name="Cancelar adição de relação" />
                                        <Button Content="Vincular conteúdos"
                                                Command="{Binding VincularConteudosCommand}"
                                                IsEnabled="{Binding PodeVincular}"
                                                AutomationProperties.Name="Vincular conteúdos" />
                                    </StackPanel>

                                </StackPanel>
                            </Border>

                        </StackPanel>

                    </StackPanel>

                </Expander>

                <!-- 4. Histórico de Consumo (collapsed — hidden for child content) -->
                <Expander IsExpanded="False"
                          IsVisible="{Binding !IsFilho}"
                          AutomationProperties.Name="Seção Histórico de Consumo: sessões e progresso">

                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Histórico de Consumo"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ResumoHistorico}"
                                       FontSize="12"
                                       Opacity="0.6"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>

                    <StackPanel Spacing="12" Margin="0,12,0,0">

                        <!-- Progress summary (UI-SPEC §7) -->
                        <StackPanel Spacing="8"
                                    Margin="0,0,0,8">
                            <TextBlock Text="{Binding ProgressoTexto}"
                                       FontSize="14"
                                       AutomationProperties.Name="{Binding ProgressoTexto, StringFormat='Progresso de consumo: {0}'}" />
                            <!-- Progress bar (visible when TotalEsperado defined) -->
                            <ProgressBar Value="{Binding ProgressoPorcentagem}"
                                         Maximum="100"
                                         Height="4"
                                         IsVisible="{Binding TotalEsperadoSessoes, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            <!-- TotalEsperado editable field -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="Total esperado de sessões"
                                           FontSize="12" />
                                <NumericUpDown Value="{Binding TotalEsperadoSessoes, Mode=TwoWay}"
                                              Minimum="1"
                                              FormatString="0"
                                              Width="100"
                                              Watermark="—"
                                              AutomationProperties.Name="Total esperado de sessões (opcional)" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Empty state -->
                        <TextBlock Text="Nenhuma sessão registrada"
                                   IsVisible="{Binding !Sessoes.Count}"
                                   Opacity="0.6"
                                   FontSize="12" />

                        <!-- Timeline (most recent first) -->
                        <ItemsControl x:Name="SessoesLista"
                                      ItemsSource="{Binding Sessoes}"
                                      AutomationProperties.Name="Timeline de sessões de consumo">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SessaoItemViewModel">
                                    <Grid ColumnDefinitions="Auto,12,*"
                                          Margin="0,0,0,8">
                                        <!-- Timeline dot -->
                                        <Ellipse Grid.Column="0"
                                                 Width="10"
                                                 Height="10"
                                                 Fill="{DynamicResource SystemAccentColor}"
                                                 VerticalAlignment="Top"
                                                 Margin="0,4,0,0" />
                                        <!-- Session card (clickable to open child modal) -->
                                        <Button Grid.Column="2"
                                                Padding="8"
                                                CornerRadius="4"
                                                HorizontalContentAlignment="Stretch"
                                                Command="{Binding AbrirCommand}"
                                                CommandParameter="{Binding Id}"
                                                AutomationProperties.Name="{Binding Titulo, StringFormat='Abrir sessão: {0}'}">
                                            <StackPanel Spacing="4">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Titulo}"
                                                               FontWeight="SemiBold"
                                                               FontSize="13" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding CriadoEm, StringFormat='{}{0:dd MMM yyyy}'}"
                                                               Opacity="0.6"
                                                               FontSize="11" />
                                                </Grid>
                                                <!-- Annotation preview (truncated) -->
                                                <TextBlock Text="{Binding Anotacoes}"
                                                           IsVisible="{Binding Anotacoes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxLines="1"
                                                           Opacity="0.6"
                                                           FontSize="12" />
                                                <!-- Classificação + Nota inline -->
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="👍"
                                                               FontSize="12"
                                                               IsVisible="{Binding IsGostei}" />
                                                    <TextBlock Text="👎"
                                                               FontSize="12"
                                                               IsVisible="{Binding IsNaoGostei}" />
                                                    <TextBlock Text="{Binding Nota, StringFormat='Nota: {0:0.#}'}"
                                                               FontSize="12"
                                                               Opacity="0.6"
                                                               IsVisible="{Binding Nota, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Registrar sessão button -->
                        <Button Content="Registrar sessão"
                                Command="{Binding MostrarFormularioSessaoCommand}"
                                IsVisible="{Binding !MostrandoFormularioSessao}"
                                AutomationProperties.Name="Registrar nova sessão de consumo"
                                Margin="0,4,0,0" />

                        <!-- Error message -->
                        <TextBlock Text="{Binding MensagemErroSessao}"
                                   IsVisible="{Binding MensagemErroSessao, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   Foreground="Red"
                                   FontSize="12" />

                        <!-- Inline miniform (stays open per D-20) -->
                        <Border IsVisible="{Binding MostrandoFormularioSessao}"
                                Padding="12"
                                CornerRadius="4"
                                Margin="0,4"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                AutomationProperties.Name="Formulário rápido para registrar sessão">
                            <StackPanel Spacing="8">

                                <!-- Título (obrigatório) -->
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Título" FontSize="12" />
                                    <TextBox Text="{Binding SessaoTitulo, Mode=TwoWay}"
                                             Watermark="Ex: Episódio 1, Capítulo 3…"
                                             AutomationProperties.Name="Título da sessão" />
                                </StackPanel>

                                <!-- Data (defaults to hoje) -->
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Data" FontSize="12" />
                                    <DatePicker SelectedDate="{Binding SessaoData, Mode=TwoWay}"
                                                AutomationProperties.Name="Data da sessão" />
                                </StackPanel>

                                <!-- Progressive disclosure toggle -->
                                <Button Content="{Binding TextoBotaoDetalhesSessao}"
                                        Command="{Binding ToggleDetalhesSessaoCommand}"
                                        FontSize="12"
                                        AutomationProperties.Name="Mostrar ou ocultar campos adicionais da sessão" />

                                <!-- Optional fields -->
                                <StackPanel IsVisible="{Binding MostrandoDetalhesSessao}"
                                            Spacing="8">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Anotações" FontSize="12" />
                                        <TextBox Text="{Binding SessaoAnotacoes, Mode=TwoWay}"
                                                 TextWrapping="Wrap"
                                                 Height="60"
                                                 AcceptsReturn="True"
                                                 AutomationProperties.Name="Anotações da sessão" />
                                    </StackPanel>
                                    <Grid ColumnDefinitions="Auto,*">
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="Nota (0–10)" FontSize="12" />
                                            <NumericUpDown Value="{Binding SessaoNota, Mode=TwoWay}"
                                                          Minimum="0"
                                                          Maximum="10"
                                                          Increment="0.5"
                                                          FormatString="0.#"
                                                          Width="80"
                                                          Watermark="—"
                                                          AutomationProperties.Name="Nota da sessão" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4" Margin="16,0,0,0">
                                            <TextBlock Text="Classificação" FontSize="12" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ToggleButton IsChecked="{Binding SessaoIsGostei}"
                                                             Width="32"
                                                             Height="32"
                                                             AutomationProperties.Name="Marcar sessão como Gostei">
                                                    <TextBlock Text="👍" FontSize="16" />
                                                </ToggleButton>
                                                <ToggleButton IsChecked="{Binding SessaoIsNaoGostei}"
                                                             Width="32"
                                                             Height="32"
                                                             AutomationProperties.Name="Marcar sessão como Não gostei">
                                                    <TextBlock Text="👎" FontSize="16" />
                                                </ToggleButton>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            HorizontalAlignment="Right">
                                    <Button Content="Fechar"
                                            Command="{Binding FecharFormularioSessaoCommand}"
                                            FontSize="12"
                                            AutomationProperties.Name="Fechar formulário de sessão" />
                                    <Button Content="Registrar sessão"
                                            Command="{Binding RegistrarSessaoCommand}"
                                            IsEnabled="{Binding PodeRegistrarSessao}"
                                            AutomationProperties.Name="Confirmar registro da sessão" />
                                </StackPanel>

                            </StackPanel>
                        </Border>

                    </StackPanel>

                </Expander>

            </StackPanel>

        </ScrollViewer>

        <!-- Row 1: Fixed footer with action buttons -->
        <Border Grid.Row="1"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                Padding="24,8"
                AutomationProperties.Name="Rodapé de ações do modal">

            <DockPanel>

                <!-- Excluir (left, destructive) -->
                <Button DockPanel.Dock="Left"
                        Content="Excluir"
                        Command="{Binding ExcluirCommand}"
                        IsEnabled="{Binding !IsSalvando}"
                        Foreground="Red"
                        AutomationProperties.Name="Excluir conteúdo"
                        AutomationProperties.HelpText="Remove permanentemente este conteúdo e todas as sessões." />

                <!-- Cancelar + Salvar (right) -->
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            HorizontalAlignment="Right">

                    <Button Content="Cancelar"
                            Command="{Binding CancelarCommand}"
                            IsEnabled="{Binding !IsSalvando}"
                            AutomationProperties.Name="Cancelar edição"
                            AutomationProperties.HelpText="Descarta as alterações e fecha o modal." />

                    <Button Content="Salvar"
                            Command="{Binding SalvarCommand}"
                            IsEnabled="{Binding !IsSalvando}"
                            AutomationProperties.Name="Salvar alterações"
                            AutomationProperties.HelpText="Salva todas as alterações feitas no conteúdo." />

                </StackPanel>

            </DockPanel>

        </Border>

    </Grid>

</Window>
