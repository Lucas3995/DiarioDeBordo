<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiarioDeBordo.UI.ViewModels"
             x:Class="DiarioDeBordo.UI.Views.CriarConteudoView"
             x:DataType="vm:CriarConteudoViewModel"
             AutomationProperties.Name="Formulário de criação de conteúdo">

    <StackPanel Spacing="12" Margin="0,4">

        <!-- Title field (always visible — progressive disclosure, D-03) -->
        <StackPanel Spacing="4">
            <TextBlock Text="Título"
                       FontWeight="Medium" />
            <TextBox Text="{Binding Titulo}"
                     Watermark="Ex: Duna, A Origem, Cálculo Vol. 1…"
                     AutomationProperties.Name="Campo título do conteúdo"
                     AutomationProperties.HelpText="Obrigatório. Digite o título do conteúdo." />
        </StackPanel>

        <!-- Error message (WCAG 3.3.1) -->
        <TextBlock Text="{Binding MensagemErro}"
                   IsVisible="{Binding MensagemErro, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Foreground="Red"
                   AutomationProperties.Name="Mensagem de erro de validação" />

        <!-- Progressive disclosure toggle (D-03; Shneiderman 1996) -->
        <Button Content="{Binding TextoBotaoDetalhes}"
                Command="{Binding ToggleDetalhesCommand}"
                AutomationProperties.Name="Alternar campos adicionais"
                AutomationProperties.HelpText="Clique para mostrar ou ocultar campos adicionais." />

        <!-- Additional fields (revealed by progressive disclosure) -->
        <StackPanel IsVisible="{Binding MostrarDetalhes}"
                    Spacing="12"
                    AutomationProperties.Name="Campos adicionais do conteúdo">

            <StackPanel Spacing="4">
                <TextBlock Text="Descrição"
                           FontWeight="Medium" />
                <TextBox Text="{Binding Descricao, Mode=TwoWay}"
                         TextWrapping="Wrap"
                         Height="80"
                         AcceptsReturn="True"
                         AutomationProperties.Name="Campo descrição do conteúdo" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Anotações"
                           FontWeight="Medium" />
                <TextBox Text="{Binding Anotacoes, Mode=TwoWay}"
                         TextWrapping="Wrap"
                         Height="80"
                         AcceptsReturn="True"
                         AutomationProperties.Name="Campo anotações do conteúdo" />
            </StackPanel>

        </StackPanel>

        <!-- Action buttons -->
        <StackPanel Orientation="Horizontal"
                    Spacing="8"
                    HorizontalAlignment="Right"
                    Margin="0,4,0,0">
            <Button Content="Cancelar"
                    Command="{Binding CancelarCommand}"
                    AutomationProperties.Name="Cancelar criação de conteúdo" />
            <Button Content="{Binding TextoBotaoSalvar}"
                    Command="{Binding SalvarCommand}"
                    IsEnabled="{Binding PodeSalvar}"
                    AutomationProperties.Name="Confirmar adição de conteúdo ao acervo" />
        </StackPanel>

    </StackPanel>
</UserControl>
